    "hono": "^4.12.25",
    "nanoid": "^5.1.5",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.7",
    "tsx": "^4.23.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }

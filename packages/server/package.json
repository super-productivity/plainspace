    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@plainspace/shared": "*",
    "dotenv": "^16.5.0",

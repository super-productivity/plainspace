# App environment
NODE_ENV=development
PORT=3000
# Public origin used for links in emails and integration responses
APP_URL=http://localhost:5173

# Postgres connection string
DATABASE_URL=postgres://spaces:spaces@localhost:5432/spaces

# Attachments are disabled (see CLAUDE.md). To re-enable, follow the restore
# steps in CLAUDE.md and add S3_ENDPOINT / S3_REGION / S3_BUCKET /
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY / S3_FORCE_PATH_STYLE here.

# Application-layer encryption for members.email and verification tables.
# 32 random bytes each, base64-encoded. The two keys must differ — enc
# decrypts emails; index drives the HMAC blind index used for lookups.
# Generate: openssl rand -base64 32   (run twice, paste below)
# In dev these can be omitted: server generates ephemeral keys on boot.
PLAINSPACE_EMAIL_ENC_KEY=
PLAINSPACE_EMAIL_INDEX_KEY=

# SMTP (leave blank in dev; emails are logged to stdout)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@localhost
CONTACT_EMAIL=hello@localhost

# Web Push (VAPID). Required in production; the reminder sweep no-ops without
# all three. Generate once: `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@localhost

# Set to 1 when running behind a reverse proxy (uses X-Forwarded-For for rate limits)
TRUST_PROXY=0

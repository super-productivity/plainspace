# Copy to `.env` on the production host (next to docker-compose.yml).
# docker-compose substitutes these into the running services.

# Public origin used in emails and integration responses.
APP_URL=https://plainspace.example.com

# Host port the container binds on 127.0.0.1. Your reverse proxy targets this.
APP_PORT=3000

# Background sweepers (reminders, retention) run by default. They are NOT
# multi-process safe: if you ever run more than one app instance, set
# RUN_SWEEPERS=0 on every replica except one.
# RUN_SWEEPERS=1

# Postgres credentials for the bundled db service.
# NOTE: POSTGRES_PASSWORD becomes part of DATABASE_URL — avoid characters that
# need URL-encoding (@ : / # ? % &). Letters/digits/-_. are safe.
POSTGRES_USER=spaces
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=spaces

# Bind address for the host port. Default 127.0.0.1 means only a reverse
# proxy on the same host can reach the container. Set to 0.0.0.0 (and
# firewall the port) if the proxy runs on a different host.
# APP_BIND=127.0.0.1

# Attachments are disabled (see CLAUDE.md). To re-enable, follow the restore
# steps in CLAUDE.md and add S3_ENDPOINT / S3_REGION / S3_BUCKET /
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY / S3_FORCE_PATH_STYLE here.

# Application-layer encryption for members.email and verification tables.
# 32 random bytes each, base64-encoded. The two keys must differ. Losing
# both keys = total PII loss; escrow in a password manager off-host.
# Generate: `openssl rand -base64 32`  (run twice, paste distinct values)
PLAINSPACE_EMAIL_ENC_KEY=replace-with-openssl-rand-base64-32
PLAINSPACE_EMAIL_INDEX_KEY=replace-with-different-openssl-rand-base64-32

# Reverse proxy in front => use X-Forwarded-For for rate limits.
TRUST_PROXY=1

# SMTP relay (your mail provider or your own mail server).
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@plainspace.example.com
SMTP_PASS=replace-with-smtp-password
FROM_EMAIL=noreply@plainspace.example.com
CONTACT_EMAIL=hello@plainspace.example.com

# Web Push (VAPID). Required in production — docker compose refuses to start
# without all three. Generate once with `npx web-push generate-vapid-keys`
# (the `web-push` dep is already in packages/server). Rotation is destructive:
# changing the keys forces every existing push_subscriptions row to be
# re-registered on the user's next visit; in-flight pushes during the gap
# are lost. Escrow both keys with the rest of your secrets.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@plainspace.example.com
